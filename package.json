{
  "name": "login-account-setup",
  "version": "0.1.0",
  "private": true,
  "description": "AI-DLC v0.1 reference implementation — login + account-setup feature",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "bash scripts/dev.sh",
    "dev:docker": "docker compose up",
