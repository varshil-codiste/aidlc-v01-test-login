{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "brand": {
      "primary": { "$value": "#016097", "$type": "color" },
      "accent":  { "$value": "#ef8022", "$type": "color" }
    },
    "neutral": {
      "0":   { "$value": "#ffffff", "$type": "color" },
      "50":  { "$value": "#f9f9f9", "$type": "color" },
      "300": { "$value": "#d1d0d0", "$type": "color" },
      "500": { "$value": "#737272", "$type": "color", "$description": "Darkened from #908d8d per NFR-A11Y-004 (Stage 8 Q1)" },
      "700": { "$value": "#5a5959", "$type": "color" },
      "900": { "$value": "#2c2b2b", "$type": "color" }
    },
    "danger": { "$value": "#dc2626", "$type": "color" }
  },
  "font": {
    "family": { "$value": "Inter, system-ui, -apple-system, sans-serif", "$type": "fontFamily" }
  },
  "radius": {
    "md":   { "$value": "6px",    "$type": "borderRadius" },
    "pill": { "$value": "9999px", "$type": "borderRadius" }
  }
}
