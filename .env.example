# --- Backend (NestJS) ---

# Postgres connection string (read by Prisma).
# When using docker-compose, the host is `db` (Compose service name).
DATABASE_URL=postgresql://app:app@db:5432/auth?schema=public

# RS256 keypair (PEM-encoded). Generate via `bash scripts/gen-keys.sh`.
# The script writes a local `.env.local` with these populated.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...replace via scripts/gen-keys.sh...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...replace via scripts/gen-keys.sh...\n-----END PUBLIC KEY-----"

# Single allowed origin for CORS (the FE).
FE_ORIGIN=http://localhost:3000

# dev | ci | prod — toggles `Secure` cookie flag + stack-trace verbosity.
APP_ENV=dev

# Optional
LOG_LEVEL=info
PORT=4000

# --- Frontend (Next.js) ---

# BE base URL the FE talks to.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
